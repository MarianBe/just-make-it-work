#!/usr/bin/env bash
#
# ticket — start an opencode orchestrator session for a ticket in its own
# git worktree, so multiple tickets can run in parallel.
#
#   ticket ABC-123                     create worktree + branch ticket/ABC-123, launch opencode
#   ticket ABC-123 develop             base the new branch on 'develop' instead of the default branch
#   ticket ABC-123 fix the tests too   worktree exists: continue its session with this feedback
#   ticket continue ABC-123 [words..]  continue the ticket's last session (feedback optional)
#   ticket cleanup ABC-123             remove the worktree (branch is kept)
#   ticket list                        list ticket worktrees for this repo
#
#   --code   open the worktree in VS Code and drive the ticket with Copilot
#            agent chat (code chat) instead of the opencode TUI
#
set -euo pipefail

die() {
  echo "ticket: $*" >&2
  exit 1
}

usage() {
  sed -n '2,15p' "$0" | sed 's/^# \{0,1\}//'
  exit "${1:-0}"
}

# strip --code out of the args; it may appear anywhere
USE_CODE=""
args=()
for a in "$@"; do
  if [ "$a" = "--code" ]; then
    USE_CODE=1
  else
    args+=("$a")
  fi
done
set -- ${args[@]+"${args[@]}"}

launch_code() {
  # $1 worktree dir, $2 prompt for Copilot agent chat (empty = just open)
  command -v code >/dev/null 2>&1 ||
    die "'code' CLI not found (VS Code: run 'Shell Command: Install code command in PATH')"
  cd "$1"
  code .
  if [ -n "${2:-}" ]; then
    # no combined open-folder-and-chat flag exists; give the window a moment
    # to become the active one, then start chat in it (-r = reuse window)
    sleep 3
    exec code chat -r -m agent "$2"
  fi
  exit 0
}

continue_session() {
  # $1 worktree dir; remaining args = optional feedback for the session
  local wt="$1"
  shift
  if [ -n "$USE_CODE" ]; then
    launch_code "$wt" "${*:-}"
  fi
  cd "$wt"
  # opencode scopes the session list to the current worktree directory, so
  # --continue picks up this ticket's latest session, not another ticket's
  if [ $# -gt 0 ]; then
    exec opencode --continue --prompt "$*"
  fi
  exec opencode --continue
}

[ $# -ge 1 ] || usage 1
case "$1" in
  -h | --help) usage 0 ;;
esac

command -v opencode >/dev/null 2>&1 || die "opencode not found in PATH (https://opencode.ai)"
root="$(git rev-parse --show-toplevel 2>/dev/null)" || die "run this inside a git repository"
repo_name="$(basename "$root")"
parent_dir="$(dirname "$root")"

worktree_path() {
  echo "${parent_dir}/${repo_name}-$1"
}

sanitize() {
  [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] || die "invalid ticket id: '$1' (letters, digits, . _ - only)"
}

case "$1" in
  list)
    git -C "$root" worktree list | grep -F "${repo_name}-" || echo "no ticket worktrees"
    exit 0
    ;;
  continue | resume)
    [ $# -ge 2 ] || die "usage: ticket continue <TICKET-ID> [feedback...]"
    sanitize "$2"
    wt="$(worktree_path "$2")"
    [ -d "$wt" ] || die "no worktree at $wt (start one with: ticket $2)"
    shift 2
    continue_session "$wt" "$@"
    ;;
  cleanup)
    [ $# -ge 2 ] || die "usage: ticket cleanup <TICKET-ID> [--force]"
    sanitize "$2"
    wt="$(worktree_path "$2")"
    [ -d "$wt" ] || die "no worktree at $wt"
    if [ "${3:-}" = "--force" ]; then
      git -C "$root" worktree remove --force "$wt"
    else
      git -C "$root" worktree remove "$wt" ||
        die "worktree has uncommitted changes; commit them or rerun with --force"
    fi
    echo "removed $wt (branch ticket/$2 kept; delete with: git branch -D ticket/$2)"
    exit 0
    ;;
esac

id="$1"
sanitize "$id"
wt="$(worktree_path "$id")"
branch="ticket/${id}"

if [ -d "$wt" ]; then
  # worktree already exists: continue its last session, extra args = feedback
  echo "worktree $wt exists, continuing its last session"
  shift
  continue_session "$wt" "$@"
fi

base="${2:-}"
if git -C "$root" show-ref --verify --quiet "refs/heads/${branch}"; then
  echo "branch ${branch} exists, reusing it"
  git -C "$root" worktree add "$wt" "$branch"
else
  if [ -z "$base" ]; then
    base="$(git -C "$root" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||')" || true
    [ -n "$base" ] || base="$(git -C "$root" symbolic-ref --short HEAD)"
  fi
  echo "creating worktree $wt (branch ${branch} from ${base})"
  git -C "$root" worktree add -b "$branch" "$wt" "$base"
fi
# bootstrap fresh worktree: setup agent executes the repo's .opencode/setup.md
# (natural-language setup instructions: install deps, copy env files, ...)
if [ -f "$wt/.opencode/setup.md" ]; then
  echo "bootstrapping worktree via setup agent (.opencode/setup.md)"
  (cd "$wt" && opencode run --agent setup \
    "Set up this fresh git worktree by following .opencode/setup.md.") ||
    echo "ticket: warning: setup agent reported failures; continuing anyway" >&2
fi

if [ -n "$USE_CODE" ]; then
  launch_code "$wt" "Work on ticket ${id}. Fetch the ticket from Linear or Jira, present a short implementation plan, then implement it on branch ${branch}, run the project's tests, and commit. Do not push."
fi

cd "$wt"
exec opencode --agent orchestrator \
  --prompt "Work on ticket ${id}. Fetch the ticket, present your implementation plan, then delegate implementation to the worker subagent and verify, per your orchestrator workflow."
